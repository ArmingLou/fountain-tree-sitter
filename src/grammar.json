{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "fountain",
  "rules": {
    "document": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "title_page_line"
        },
        {
          "type": "SYMBOL",
          "name": "section"
        },
        {
          "type": "SYMBOL",
          "name": "synopsis"
        },
        {
          "type": "SYMBOL",
          "name": "scene_heading"
        },
        {
          "type": "SYMBOL",
          "name": "transition"
        },
        {
          "type": "SYMBOL",
          "name": "centered"
        },
        {
          "type": "SYMBOL",
          "name": "character_line"
        },
        {
          "type": "SYMBOL",
          "name": "parenthetical"
        },
        {
          "type": "SYMBOL",
          "name": "dialogue"
        },
        {
          "type": "SYMBOL",
          "name": "page_break"
        },
        {
          "type": "SYMBOL",
          "name": "lyrics"
        },
        {
          "type": "SYMBOL",
          "name": "note_inline"
        },
        {
          "type": "SYMBOL",
          "name": "boneyard"
        },
        {
          "type": "SYMBOL",
          "name": "separator"
        },
        {
          "type": "SYMBOL",
          "name": "action"
        }
      ]
    },
    "title_page_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Title:"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        }
      ]
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        }
      ]
    },
    "synopsis": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        }
      ]
    },
    "scene_heading": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "INT."
            },
            {
              "type": "SYMBOL",
              "name": "scene_location"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "EXT."
            },
            {
              "type": "SYMBOL",
              "name": "scene_location"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "EST."
            },
            {
              "type": "SYMBOL",
              "name": "scene_location"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "INT./EXT."
            },
            {
              "type": "SYMBOL",
              "name": "scene_location"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "."
            },
            {
              "type": "SYMBOL",
              "name": "scene_location"
            }
          ]
        }
      ]
    },
    "scene_location": {
      "type": "SYMBOL",
      "name": "word"
    },
    "transition": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        }
      ]
    },
    "centered": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "STRING",
          "value": "<"
        }
      ]
    },
    "page_break": {
      "type": "STRING",
      "value": "==="
    },
    "separator": {
      "type": "STRING",
      "value": "---"
    },
    "lyrics": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "~"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        }
      ]
    },
    "character_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "("
                },
                {
                  "type": "SYMBOL",
                  "name": "word"
                },
                {
                  "type": "STRING",
                  "value": ")"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "parenthetical": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "dialogue": {
      "type": "SYMBOL",
      "name": "word"
    },
    "note_inline": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "[["
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "STRING",
          "value": "]]"
        }
      ]
    },
    "boneyard": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/*"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "STRING",
          "value": "*/"
        }
      ]
    },
    "action": {
      "type": "SYMBOL",
      "name": "word"
    },
    "word": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\t ]+"
    }
  ],
  "conflicts": [
    [
      "action",
      "dialogue",
      "character_line"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}